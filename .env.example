# Copy this file to .env for local development
# On Render/Railway/Fly.io: set these in the Environment Variables section

# Required: your OpenRouter API key (https://openrouter.ai/keys) — free, no credit card needed
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the default LLM model
# Default (fastest free model, benchmarked 2026-05-16): openai/gpt-oss-20b:free
# Fallback chain: openai/gpt-oss-20b:free → minimax/minimax-m2.5:free → openai/gpt-oss-120b:free
# Any free model from https://openrouter.ai/models?q=:free works here
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
