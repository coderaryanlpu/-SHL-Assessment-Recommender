# Copy this file to .env for local development
# On Render: set these in the Environment Variables section of your service dashboard

# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the default model (default: deepseek/deepseek-v4-flash:free)
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
